@page "/"
@using Aura.Web.Models
@using Blazored.LocalStorage
@inject ILocalStorageService LocalStorage

<PageTitle>Aura - Meu Dia</PageTitle>

<div class="dashboard-container">
    <header class="header">
        <h1 class="titulo-principal">Meu Dia 🌟</h1>
        <p class="subtitulo">Gerencie sua energia, não apenas seu tempo.</p>
        
        <div class="energia-card @(EnergiaGasta >= LimiteEnergia ? "alerta-burnout" : "energia-ok")">
            <h3 class="energia-titulo">Carga Cognitiva Atual</h3>
            <h2 class="energia-valor">@EnergiaGasta / @LimiteEnergia 🥄 colheres</h2>
            @if (EnergiaGasta >= LimiteEnergia)
            {
                <p class="energia-aviso"><strong>Atenção:</strong> Você atingiu seu limite seguro de energia. Considere adiar algumas tarefas para amanhã para evitar o esgotamento!</p>
            }
        </div>
    </header>

    <section class="card-section">
        <h3 class="section-titulo">Nova Tarefa</h3>
        <div class="form-grupo">
            <input @bind="novaTarefa.Titulo" placeholder="O que você precisa fazer?" class="input-dark" />
            
            <div class="select-wrapper">
                <label>Custo:</label>
                <select @bind="novaTarefa.CustoEnergia" class="input-dark select-dark">
                    <option value="1">1 - Leve</option>
                    <option value="3">3 - Moderada</option>
                    <option value="5">5 - Exaustiva</option>
                </select>
            </div>
            
            <button @onclick="AdicionarTarefa" class="btn btn-primario">Adicionar</button>
        </div>
        <span class="erro-msg">@mensagemErro</span>
    </section>

    <section class="lista-section">
        <h3 class="section-titulo">Suas Tarefas</h3>
        @if (tarefas.Count == 0)
        {
            <div class="card-section empty-state">
                <p>Seu dia está livre! Aproveite para descansar. ☕</p>
            </div>
        }
        else
        {
            <ul class="lista-tarefas">
                @foreach (var tarefa in tarefas.Where(t => !t.Concluida))
                {
                    <li class="tarefa-item">
                        <div class="tarefa-info">
                            <strong class="tarefa-nome">@tarefa.Titulo</strong>
                            <span class="badge-energia">@tarefa.CustoEnergia 🥄</span>
                        </div>
                        <div class="tarefa-acoes">
                            <button @onclick="() => ConcluirTarefa(tarefa.Id)" class="btn btn-sucesso">Concluir</button>
                            <button @onclick="() => ExcluirTarefa(tarefa.Id)" class="btn btn-perigo">Excluir</button>
                        </div>
                    </li>
                }
            </ul>
        }
    </section>
</div>

@code {
    // --- O BLOCO C# CONTINUA EXATAMENTE IGUAL ---
    private List<Tarefa> tarefas = new();
    private Tarefa novaTarefa = new() { CustoEnergia = 1 };
    private string mensagemErro = "";
    
    private int LimiteEnergia = 15; 
    private int EnergiaGasta => tarefas.Where(t => !t.Concluida).Sum(t => t.CustoEnergia);

    protected override async Task OnInitializedAsync()
    {
        var tarefasSalvas = await LocalStorage.GetItemAsync<List<Tarefa>>("aura_tarefas");
        if (tarefasSalvas != null)
        {
            tarefas = tarefasSalvas;
        }
    }

    private async Task AdicionarTarefa()
    {
        if (string.IsNullOrWhiteSpace(novaTarefa.Titulo))
        {
            mensagemErro = "Por favor, digite o nome da tarefa.";
            return;
        }

        mensagemErro = "";
        tarefas.Add(novaTarefa);
        novaTarefa = new Tarefa { CustoEnergia = 1 }; 
        await SalvarDados();
    }

    private async Task ConcluirTarefa(Guid id)
    {
        var tarefa = tarefas.FirstOrDefault(t => t.Id == id);
        if (tarefa != null)
        {
            tarefa.Concluida = true;
            await SalvarDados();
        }
    }

    private async Task ExcluirTarefa(Guid id)
    {
        var tarefa = tarefas.FirstOrDefault(t => t.Id == id);
        if (tarefa != null)
        {
            tarefas.Remove(tarefa);
            await SalvarDados();
        }
    }

    private async Task SalvarDados()
    {
        await LocalStorage.SetItemAsync("aura_tarefas", tarefas);
    }
}

<style>
    /* POLIMENTO FINAL - UI DARK MODE */
    .dashboard-container { 
        width: 100%; 
        max-width: 650px; 
        margin: 0 auto; 
    }
    
    .header { text-align: center; margin-bottom: 2.5rem; }
    .titulo-principal { font-size: 2.5rem; margin-bottom: 0.5rem; color: #fff; font-weight: 700; }
    .subtitulo { color: #a0aec0; font-size: 1.1rem; margin-top: 0; }
    
    /* Cartões Modernos */
    .card-section, .tarefa-item { 
        background: #1e1e1e; 
        padding: 1.5rem; 
        border-radius: 12px; 
        border: 1px solid #2d3748;
        box-shadow: 0 4px 6px rgba(0,0,0,0.2); 
        margin-bottom: 2rem;
    }

    .empty-state { text-align: center; color: #a0aec0; font-style: italic; }
    .section-titulo { color: #fff; margin-top: 0; margin-bottom: 1.2rem; font-weight: 600; }

    /* Barra de Energia */
    .energia-card { 
        padding: 1.5rem; 
        border-radius: 12px; 
        margin-top: 1.5rem; 
        color: #fff; 
        box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.3);
        transition: all 0.3s ease;
    }
    .energia-ok { background: linear-gradient(135deg, #2b6cb0, #2c5282); }
    .alerta-burnout { 
        background: linear-gradient(135deg, #c53030, #9b2c2c); 
        border: 2px solid #fc8181;
    }
    .energia-titulo { margin: 0 0 0.5rem 0; font-weight: 500; opacity: 0.9; font-size: 1.1rem; }
    .energia-valor { margin: 0; font-size: 2.5rem; font-weight: bold; }
    .energia-aviso { margin-top: 1rem; background: rgba(0,0,0,0.2); padding: 0.8rem; border-radius: 8px; font-size: 0.95rem; }

    /* Formulário Escuro */
    .form-grupo { display: flex; gap: 12px; align-items: center; flex-wrap: wrap; }
    .select-wrapper { display: flex; align-items: center; gap: 8px; color: #a0aec0; font-size: 0.9rem; }
    .input-dark { 
        background: #2d3748; 
        color: #fff; 
        border: 1px solid #4a5568; 
        padding: 0.8rem 1rem; 
        border-radius: 8px; 
        flex-grow: 1; 
        font-size: 1rem;
        transition: border-color 0.2s;
    }
    .input-dark:focus { outline: none; border-color: #63b3ed; }
    .input-dark::placeholder { color: #718096; }
    .select-dark { min-width: 130px; cursor: pointer; }
    .erro-msg { color: #fc8181; font-size: 0.85rem; display: block; margin-top: 8px; }

    /* Botões */
    .btn { 
        font-weight: 600; border: none; padding: 0.8rem 1.2rem; border-radius: 8px; cursor: pointer; 
        transition: all 0.2s ease; font-size: 0.95rem; display: inline-flex; justify-content: center; align-items: center;
    }
    .btn-primario { background: #3182ce; color: white; flex-grow: 1; }
    .btn-primario:hover { background: #2b6cb0; transform: translateY(-1px); }
    .btn-sucesso { background: #38a169; color: white; padding: 0.5rem 1rem; }
    .btn-sucesso:hover { background: #2f855a; transform: translateY(-1px); }
    .btn-perigo { background: transparent; color: #fc8181; border: 1px solid #fc8181; padding: 0.5rem 1rem; }
    .btn-perigo:hover { background: rgba(252, 129, 129, 0.1); }

    /* Lista de Tarefas */
    .lista-tarefas { list-style: none; padding: 0; margin: 0; }
    .tarefa-item { display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.8rem; padding: 1.2rem; }
    .tarefa-nome { font-size: 1.1rem; color: #e2e8f0; }
    .badge-energia { 
        background: #2d3748; padding: 0.3rem 0.6rem; border-radius: 20px; font-size: 0.85rem; 
        color: #cbd5e0; margin-left: 12px; border: 1px solid #4a5568;
    }
    .tarefa-acoes { display: flex; gap: 8px; }

    /* Responsividade */
    @@media (max-width: 480px) {
        .form-grupo { flex-direction: column; align-items: stretch; }
        .tarefa-item { flex-direction: column; align-items: flex-start; gap: 15px; }
        .tarefa-acoes { width: 100%; justify-content: space-between; }
        .btn { width: 100%; }
        .btn-sucesso, .btn-perigo { flex-grow: 1; }
    }
</style>